global:
  checkNewVersion: false
  sendAnonymousUsage: false
log:
  level: DEBUG
api:
  dashboard: true
  insecure: false

entryPoints:
  web:
    address: ":80"
  websecure:
    address: ":443"
    http:
      tls: {}
certificatesResolvers:
  letsencrypt:
    acme:
      email: "{{ certificate_notify_email }}"
      storage: /opt/traefik/letsencrypt/acme.json
      httpChallenge:
        # used during the challenge
        entryPoint: web
providers:
  docker:
    endpoint: "unix:///var/run/docker.sock"
    exposedByDefault: false
