{
  "name": "@vittav-repos/checkmate-apis-e2e",
  "version": "0.0.1",
  "private": true,
  "nx": {
    "implicitDependencies": [
      "@vittav-repos/checkmate-apis"
    ],
    "targets": {
      "e2e": {
        "executor": "@nx/jest:jest",
        "outputs": [
          "{projectRoot}/test-output/jest/coverage"
        ],
        "options": {
          "jestConfig": "apps/checkmate-apis-e2e/jest.config.cts",
          "passWithNoTests": true
        },
        "dependsOn": [
          "@vittav-repos/checkmate-apis:build",
          "@vittav-repos/checkmate-apis:serve"
        ]
      }
    }
  }
}
