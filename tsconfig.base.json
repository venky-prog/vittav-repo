{
  "compilerOptions": {
    "composite": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "importHelpers": true,
    "isolatedModules": true,
    "lib": [
      "es2022"
    ],
    "module": "esnext",
    "moduleResolution": "bundler",
    "noEmitOnError": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "es2022",
    "customConditions": [
      "@vittav-repos/source"
    ],
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "paths": {
      "@vittav-repos/core-ui": ["libs/core-ui/src/index.ts"],
      "@vittav-repos/utils": ["libs/utils/src/index.ts"],
      "@vittav-repos/core-ui/hooks": ["libs/core-ui/src/hooks"],
      "@vittav-repos/core-ui/components": ["libs/core-ui/src/components"]
    }
  }
}
